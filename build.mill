package build

import mill._
import mill.kotlinlib._

// Detect OS/arch for Skiko platform dependency
val osName: String = System.getProperty("os.name")
val targetOs: String = osName match {
  case "Mac OS X"                  => "macos"
  case s if s.startsWith("Win")   => "windows"
  case s if s.startsWith("Linux") => "linux"
  case _                           => sys.error(s"Unsupported OS: $osName")
}
val osArch: String = System.getProperty("os.arch")
val targetArch: String = osArch match {
  case "x86_64" | "amd64" => "x64"
  case "aarch64"           => "arm64"
  case _                    => sys.error(s"Unsupported arch: $osArch")
}
val skikoTarget = s"$targetOs-$targetArch"
val skikoVersion = "0.144.2"
val kotlinVer = "2.2.20"

/** Shared base for all Kotlin modules in this project. */
trait GartKotlinModule extends KotlinModule {
  def kotlinVersion = kotlinVer
  def kotlincOptions = super.kotlincOptions() ++ Seq("-Xcontext-parameters")
  // Match Gradle source layout: src/main/kotlin
  def sources = Task.Sources(moduleDir / "src" / "main" / "kotlin")
  def resources = Task.Sources(moduleDir / "src" / "main" / "resources")
  def repositoriesTask = Task.Anon {
    super.repositoriesTask() ++ Seq(
      coursier.Repositories.central,
      coursier.maven.MavenRepository("https://redirector.kotlinlang.org/maven/compose-dev")
    )
  }
}

/** Art module that depends only on :gart */
trait ArtModule extends GartKotlinModule {
  def moduleDeps = Seq(gart)
}

/** Art module that depends on :gart and :gart-box2d */
trait ArtBox2dModule extends GartKotlinModule {
  def moduleDeps = Seq(gart, `gart-box2d`)
}

// ---------------------------------------------------------------------------
// Core modules
// ---------------------------------------------------------------------------

object gart extends GartKotlinModule {
  def mvnDeps = Seq(
    mvn"org.jetbrains.skiko:skiko-awt-runtime-${skikoTarget}:${skikoVersion}",
    mvn"org.jetbrains.kotlinx:kotlinx-coroutines-core:1.10.2",
    mvn"org.bytedeco:ffmpeg-platform:7.1.1-1.5.12",
    mvn"org.bytedeco:ffmpeg-platform-gpl:7.1.1-1.5.12",
  )

  object test extends KotlinTests with TestModule.Junit5 {
    def sources = Task.Sources(gart.moduleDir / "src" / "test" / "kotlin")
    def resources = Task.Sources(gart.moduleDir / "src" / "test" / "resources")
    def mvnDeps = Seq(
      mvn"org.jetbrains.kotlin:kotlin-test-junit5:$kotlinVer",
      mvn"org.junit.platform:junit-platform-launcher:1.11.4",
    )
  }
}

object `gart-box2d` extends GartKotlinModule {
  def moduleDeps = Seq(gart)
  def mvnDeps = Seq(
    mvn"de.pirckheimer-gymnasium:jbox2d-library:3.1.0",
  )
}

object example extends GartKotlinModule {
  def moduleDeps = Seq(gart, `gart-box2d`)
  def mainClass = Some("dev.oblac.gart.GenerateReadMeKt")
}

object ppt extends GartKotlinModule {
  def moduleDeps = Seq(gart, `gart-box2d`)
  def mainClass = Some("dev.oblac.gart.ppt.MainKt")
}

// ---------------------------------------------------------------------------
// Art projects
// ---------------------------------------------------------------------------

