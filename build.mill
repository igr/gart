  object bubbles      extends ArtModule
  object lettero      extends ArtModule
  object roundrects   extends ArtModule
  object palecircles  extends ArtModule
  object spiral       extends ArtModule
  object lissajous    extends ArtModule
  object harmongraph  extends ArtModule
  object flowforce    extends ArtModule
  object repetition   extends ArtModule
  object rects        extends ArtModule
  object metro        extends ArtModule
  object cotton       extends ArtModule
  object thre3        extends ArtModule
  object igor         extends ArtModule
  object flamebrush   extends ArtModule
  object rectapart    extends ArtModule
  object legoo        extends ArtModule
  object triangular   extends ArtModule
  object switchboard  extends ArtModule
  object stripes      extends ArtModule
  object sun          extends ArtModule
  object blob         extends ArtModule
  object monet        extends ArtModule
  object lines        extends ArtModule
  object pixelmania   extends ArtModule
  object neuromancer  extends ArtModule
